# ─── AWS Core ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# AWS credentials (use IAM role on ECS/Lambda — do NOT hardcode in production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── AWS Bedrock ──────────────────────────────────────────────────────────────
# Claude 3.5 Sonnet on Bedrock (ensure model access is enabled in AWS console)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ─── DynamoDB Tables ──────────────────────────────────────────────────────────
DYNAMODB_TABLE_REPORTS=afm-reports
DYNAMODB_TABLE_AUDIT=afm-audit-logs
DYNAMODB_TABLE_NOTIFICATIONS=afm-notifications

# ─── S3 ───────────────────────────────────────────────────────────────────────
# Bucket for storing original PDF reports (encrypted at rest)
S3_BUCKET_PDF=afm-pdf-reports

# ─── SQS Queues ───────────────────────────────────────────────────────────────
# FIFO queue for ordered report processing
SQS_PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/afm-processing.fifo
# Standard queue for escalation delay messages (DelaySeconds=300)
SQS_ESCALATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/afm-escalation
# Standard queue for snooze expiry notifications
SQS_SNOOZE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/afm-snooze

# ─── SNS Topics ───────────────────────────────────────────────────────────────
SNS_TOPIC_CRITICAL_REPORTS=arn:aws:sns:us-east-1:ACCOUNT_ID:afm-critical-reports
SNS_TOPIC_ESCALATIONS=arn:aws:sns:us-east-1:ACCOUNT_ID:afm-escalations
SNS_TOPIC_SNOOZE_EXPIRY=arn:aws:sns:us-east-1:ACCOUNT_ID:afm-snooze-expiry

# ─── Application Settings ─────────────────────────────────────────────────────
EHR_BASE_URL=https://ehr.example.com
DEPT_HEAD_ID=dept-head
ESCALATION_TIMEOUT_SECONDS=300
